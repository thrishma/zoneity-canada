# Supabase — create a NEW project at supabase.com for this hackathon
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_POSTGRES_TRANSACTION_POOLER=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OpenAI
OPENAI_API_KEY=sk-...

# App URL (used by chat API to call itself for search)
NEXT_PUBLIC_APP_URL=http://localhost:3000
